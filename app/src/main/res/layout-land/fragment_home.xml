<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:clipToPadding="false"
    tools:context=".ui.home.HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/space_lg"
        android:paddingTop="@dimen/space_lg"
        android:paddingBottom="@dimen/bottomnav_safe_area">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <!-- LEFT column: Share mode + Token -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_md"
                android:layout_weight="1.1"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.NaviToTesla.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/shareMode"
                            android:textAppearance="@style/TextAppearance.NaviToTesla.SectionTitle" />

                        <RadioGroup
                            android:id="@+id/radioGroupShareMode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_md"
                            android:orientation="horizontal">

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/radioUsingTeslaApi"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="@dimen/space_xl"
                                android:text="@string/usingTeslaApi" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/radioUsingTeslaApp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/usingTeslaApp" />
                        </RadioGroup>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:text="@string/helperShareMode"
                            android:textAppearance="@style/TextAppearance.NaviToTesla.Helper" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.NaviToTesla.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sectionToken"
                            android:textAppearance="@style/TextAppearance.NaviToTesla.SectionTitle" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_md"
                            android:hint="@string/refreshToken"
                            app:helperText="@string/helperRefreshToken">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/txtRefreshToken"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="monospace"
                                android:inputType="textMultiLine"
                                android:maxLines="3"
                                android:minLines="1"
                                android:textSize="13sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnPaste"
                                style="@style/Widget.Material3.Button.OutlinedButton.Icon"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="@dimen/space_sm"
                                android:layout_weight="1"
                                android:text="@string/paste"
                                app:icon="@drawable/ic_baseline_content_paste_24" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnSave"
                                style="@style/Widget.Material3.Button.Icon"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/save"
                                app:icon="@drawable/ic_baseline_save_24" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_lg"
                            android:text="@string/accessToken"
                            android:textAppearance="@style/TextAppearance.NaviToTesla.SectionLabel" />

                        <TextView
                            android:id="@+id/txtAccessToken"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:background="?attr/colorSurfaceContainerHigh"
                            android:fontFamily="monospace"
                            android:maxLines="3"
                            android:minLines="1"
                            android:padding="@dimen/space_md"
                            android:scrollbars="vertical"
                            android:textIsSelectable="true"
                            android:textSize="12sp"
                            tools:text="eyJhbGciOiJSUzI1NiIsImtpZCI6Ijg4N…" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- RIGHT column: Vehicle + Maintenance -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.NaviToTesla.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/vehicle"
                            android:textAppearance="@style/TextAppearance.NaviToTesla.SectionTitle" />

                        <Spinner
                            android:id="@+id/vehicleSelector"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:minHeight="48dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.NaviToTesla.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sectionMaintenance"
                            android:textAppearance="@style/TextAppearance.NaviToTesla.SectionTitle" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTokenClear"
                            style="@style/Widget.Material3.Button.OutlinedButton.Icon"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_md"
                            android:text="@string/clearToken"
                            app:icon="@drawable/ic_baseline_clear_24" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPoiCacheClear"
                            style="@style/Widget.Material3.Button.OutlinedButton.Icon"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:text="@string/clearAddressCache"
                            app:icon="@drawable/ic_baseline_clear_24" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/txtVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/space_xl"
            android:gravity="center"
            android:text="@string/textVersion"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            tools:text="1.0" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
