<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:clipToPadding="false"
    tools:context=".ui.setting.SettingFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/space_lg"
        android:paddingTop="@dimen/space_lg"
        android:paddingBottom="@dimen/bottomnav_safe_area">

        <!-- LEFT column: Service + Behavior + Send mode + Diagnostics -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/space_md"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Card: Service -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.NaviToTesla.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sectionService"
                        android:textAppearance="@style/TextAppearance.NaviToTesla.SectionTitle" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textAccEnable"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/accessibilityService"
                            android:textAppearance="?attr/textAppearanceTitleSmall" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAccEnableHelp"
                            style="@style/Widget.NaviToTesla.HelpButton" />
                    </LinearLayout>

                    <RadioGroup
                        android:id="@+id/radioGroupAccEnable"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:orientation="horizontal">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioAccEnable"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/space_xl"
                            android:text="@string/enable" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioAccDisable"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/disable" />
                    </RadioGroup>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/space_md"
                        android:background="?attr/colorOutlineVariant" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textAppEnable"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/appActive"
                            android:textAppearance="?attr/textAppearanceTitleSmall" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAppEnableHelp"
                            style="@style/Widget.NaviToTesla.HelpButton" />
                    </LinearLayout>

                    <RadioGroup
                        android:id="@+id/radioGroupAppEnable"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:orientation="horizontal">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioAppEnable"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/space_xl"
                            android:text="@string/enable" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioAppDisable"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/disable" />
                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Behavior -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.NaviToTesla.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sectionBehavior"
                        android:textAppearance="@style/TextAppearance.NaviToTesla.SectionTitle" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textDuplicatePoiSelection"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/duplicatePoiSelection"
                            android:textAppearance="?attr/textAppearanceTitleSmall" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDuplicatePoiHelp"
                            style="@style/Widget.NaviToTesla.HelpButton" />
                    </LinearLayout>

                    <RadioGroup
                        android:id="@+id/radioGroupDuplicatePoiSelection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:orientation="horizontal">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioDuplicatePoiShowPopup"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/space_lg"
                            android:text="@string/duplicatePoiShowPopup" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioDuplicatePoiIgnore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/duplicatePoiIgnoreOption" />
                    </RadioGroup>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/space_md"
                        android:background="?attr/colorOutlineVariant" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textCondition"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/condition"
                            android:textAppearance="?attr/textAppearanceTitleSmall" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnConditionHelp"
                            style="@style/Widget.NaviToTesla.HelpButton" />
                    </LinearLayout>

                    <RadioGroup
                        android:id="@+id/radioGroupConditionEnable"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:orientation="horizontal">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioConditionEnable"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/space_xl"
                            android:text="@string/enable" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioConditionDisable"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/disable" />
                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Send mode (default + fallback) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSendMode"
                style="@style/Widget.NaviToTesla.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sectionSendMode"
                        android:textAppearance="@style/TextAppearance.NaviToTesla.SectionTitle" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/defaultSendModeTitle"
                            android:textAppearance="?attr/textAppearanceTitleSmall" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDefaultSendModeHelp"
                            style="@style/Widget.NaviToTesla.HelpButton" />
                    </LinearLayout>

                    <RadioGroup
                        android:id="@+id/radioGroupDefaultSendMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:orientation="horizontal">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioDefaultSendModeRoad"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/space_lg"
                            android:text="@string/sendModeRoad" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioDefaultSendModeJibun"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/space_lg"
                            android:text="@string/sendModeJibun" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioDefaultSendModeName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sendModeName" />
                    </RadioGroup>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/space_md"
                        android:background="?attr/colorOutlineVariant" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/fallbackSendModeTitle"
                            android:textAppearance="?attr/textAppearanceTitleSmall" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFallbackSendModeHelp"
                            style="@style/Widget.NaviToTesla.HelpButton" />
                    </LinearLayout>

                    <RadioGroup
                        android:id="@+id/radioGroupFallbackSendMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:orientation="horizontal">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioFallbackSendModeRoad"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/space_lg"
                            android:text="@string/sendModeRoad" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioFallbackSendModeJibun"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/space_lg"
                            android:text="@string/sendModeJibun" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/radioFallbackSendModeName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sendModeName" />
                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Diagnostics -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDiagnostics"
                style="@style/Widget.NaviToTesla.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/diagHeader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingVertical="@dimen/space_xs">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/sectionDiagnostics"
                            android:textAppearance="@style/TextAppearance.NaviToTesla.SectionTitle" />

                        <ImageView
                            android:id="@+id/diagExpandIcon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:importantForAccessibility="no"
                            android:src="@drawable/ic_expand_more_20"
                            tools:ignore="ContentDescription" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/diagContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <include
                            android:id="@+id/diagRowNotification"
                            layout="@layout/view_diagnostic_row"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm" />

                        <include
                            android:id="@+id/diagRowNotificationListener"
                            layout="@layout/view_diagnostic_row"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />

                        <include
                            android:id="@+id/diagRowOverlay"
                            layout="@layout/view_diagnostic_row"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />

                        <include
                            android:id="@+id/diagRowLogFile"
                            layout="@layout/view_diagnostic_log_row"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- RIGHT column: Bluetooth -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardBluetooth"
            style="@style/Widget.NaviToTesla.Card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtBluetooth"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/bluetooth"
                        android:textAppearance="@style/TextAppearance.NaviToTesla.SectionTitle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBluetoothAdd"
                        style="@style/Widget.NaviToTesla.AddButton"
                        android:contentDescription="@string/titleAddCondition"
                        app:icon="@drawable/ic_baseline_add_24"
                        tools:ignore="SpeakableTextPresentCheck" />
                </LinearLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/bluetooth_list_height"
                    android:layout_marginTop="@dimen/space_sm">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recylerBluetooth"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:overScrollMode="ifContentScrolls" />

                    <TextView
                        android:id="@+id/textBluetoothEmpty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/emptyBluetoothList"
                        android:textAlignment="center"
                        android:textAppearance="@style/TextAppearance.NaviToTesla.Helper" />
                </FrameLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
