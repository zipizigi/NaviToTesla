<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:baselineAligned="false"
    android:orientation="horizontal"
    android:paddingHorizontal="@dimen/space_lg"
    android:paddingTop="@dimen/space_lg"
    android:paddingBottom="@dimen/bottomnav_safe_area"
    tools:context=".ui.favorite.FavoriteFragment">

    <!-- Card: Favorites -->
    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.NaviToTesla.Card"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="@dimen/space_md"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtFavorite"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/favorite"
                    android:textAppearance="@style/TextAppearance.NaviToTesla.SectionTitle" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFavoriteHelp"
                    style="@style/Widget.NaviToTesla.HelpButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFavoriteAdd"
                    style="@style/Widget.NaviToTesla.AddButton"
                    android:layout_marginStart="@dimen/space_xs"
                    android:contentDescription="@string/favoriteName"
                    app:icon="@drawable/ic_baseline_add_24"
                    tools:ignore="SpeakableTextPresentCheck" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recylerRegistered"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/space_sm"
                android:layout_weight="1"
                android:overScrollMode="ifContentScrolls" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Card: Recent destinations -->
    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.NaviToTesla.Card"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtRecent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recentDestination"
                android:textAppearance="@style/TextAppearance.NaviToTesla.SectionTitle" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recylerHistory"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/space_sm"
                android:layout_weight="1"
                android:overScrollMode="ifContentScrolls" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
