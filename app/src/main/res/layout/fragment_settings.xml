<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:clipToPadding="false"
    tools:context=".ui.setting.SettingFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/space_lg"
        android:paddingTop="@dimen/space_lg"
        android:paddingBottom="@dimen/bottomnav_safe_area">

        <!-- Card: Service (Accessibility + App enable) -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.NaviToTesla.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sectionService"
                    android:textAppearance="@style/TextAppearance.NaviToTesla.SectionTitle" />

                <!-- Accessibility row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textAccEnable"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/accessibilityService"
                        android:textAppearance="?attr/textAppearanceTitleSmall" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAccEnableHelp"
                        style="@style/Widget.NaviToTesla.HelpButton" />
                </LinearLayout>

                <RadioGroup
                    android:id="@+id/radioGroupAccEnable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:orientation="horizontal">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioAccEnable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/space_xl"
                        android:text="@string/enable" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioAccDisable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/disable" />
                </RadioGroup>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="@dimen/space_md"
                    android:background="?attr/colorOutlineVariant" />

                <!-- App enable row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textAppEnable"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/appActive"
                        android:textAppearance="?attr/textAppearanceTitleSmall" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAppEnableHelp"
                        style="@style/Widget.NaviToTesla.HelpButton" />
                </LinearLayout>

                <RadioGroup
                    android:id="@+id/radioGroupAppEnable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:orientation="horizontal">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioAppEnable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/space_xl"
                        android:text="@string/enable" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioAppDisable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/disable" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card: Behavior (Duplicate POI + Condition) -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.NaviToTesla.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sectionBehavior"
                    android:textAppearance="@style/TextAppearance.NaviToTesla.SectionTitle" />

                <!-- Duplicate POI row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textDuplicatePoiSelection"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/duplicatePoiSelection"
                        android:textAppearance="?attr/textAppearanceTitleSmall" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDuplicatePoiHelp"
                        style="@style/Widget.NaviToTesla.HelpButton" />
                </LinearLayout>

                <RadioGroup
                    android:id="@+id/radioGroupDuplicatePoiSelection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:orientation="horizontal">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioDuplicatePoiShowPopup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/space_lg"
                        android:text="@string/duplicatePoiShowPopup" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioDuplicatePoiIgnore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/duplicatePoiIgnoreOption" />
                </RadioGroup>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="@dimen/space_md"
                    android:background="?attr/colorOutlineVariant" />

                <!-- Condition row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textCondition"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/condition"
                        android:textAppearance="?attr/textAppearanceTitleSmall" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnConditionHelp"
                        style="@style/Widget.NaviToTesla.HelpButton" />
                </LinearLayout>

                <RadioGroup
                    android:id="@+id/radioGroupConditionEnable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:orientation="horizontal">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioConditionEnable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/space_xl"
                        android:text="@string/enable" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioConditionDisable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/disable" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card: Bluetooth whitelist -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.NaviToTesla.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtBluetooth"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/bluetooth"
                        android:textAppearance="@style/TextAppearance.NaviToTesla.SectionTitle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBluetoothAdd"
                        style="@style/Widget.NaviToTesla.AddButton"
                        android:contentDescription="@string/titleAddCondition"
                        app:icon="@drawable/ic_baseline_add_24"
                        tools:ignore="SpeakableTextPresentCheck" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recylerBluetooth"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/bluetooth_list_height"
                    android:layout_marginTop="@dimen/space_sm"
                    android:overScrollMode="ifContentScrolls" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:text="@string/emptyBluetoothList"
                    android:textAlignment="center"
                    android:textAppearance="@style/TextAppearance.NaviToTesla.Helper" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
